<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <template id="report_supplier_contract">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="contract">
        <t t-call="web.external_layout_standard">
          <t t-set="o" t-value="contract" />
          <t t-set="company" t-value="contract.company_id" />
          <div class="page">
            <h3 class="text-center">Supplier Contract</h3>

            <table class="table table-sm o_main_table" style="margin-top: 16px;">
              <tbody>
                <tr>
                  <td style="width: 32%;"><strong>Contract</strong></td>
                  <td t-esc="contract.name or '-'" />
                </tr>
                <tr>
                  <td><strong>Supplier</strong></td>
                  <td t-esc="contract.partner_id.display_name or '-'" />
                </tr>
                <tr>
                  <td><strong>Company</strong></td>
                  <td t-esc="contract.company_id.display_name or '-'" />
                </tr>
                <tr>
                  <td><strong>Start Date</strong></td>
                  <td>
                    <span
                                            t-field="contract.date_start"
                                            t-options="{'widget': 'date'}"
                                        />
                  </td>
                </tr>
                <tr>
                  <td><strong>End Date</strong></td>
                  <td>
                    <span t-field="contract.date_end" t-options="{'widget': 'date'}" />
                  </td>
                </tr>
                <tr>
                  <td><strong>Next Invoice Date</strong></td>
                  <td>
                    <span
                                            t-field="contract.recurring_next_date"
                                            t-options="{'widget': 'date'}"
                                        />
                  </td>
                </tr>
              </tbody>
            </table>

            <h4 style="margin-top: 18px;">Recurring Lines</h4>
            <table class="table table-sm o_main_table">
              <thead>
                <tr>
                  <th>Description</th>
                  <th class="text-right">Qty</th>
                  <th class="text-right">Unit Price</th>
                  <th class="text-right">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                <tr
                                    t-foreach="contract.contract_line_ids.filtered(lambda l: not l.display_type)"
                                    t-as="line"
                                >
                  <td t-esc="line.name" />
                  <td class="text-right">
                    <span t-field="line.quantity" />
                  </td>
                  <td class="text-right">
                    <span
                                            t-field="line.price_unit"
                                            t-options="{'widget': 'monetary', 'display_currency': contract.currency_id}"
                                        />
                  </td>
                  <td class="text-right">
                    <span
                                            t-field="line.price_subtotal"
                                            t-options="{'widget': 'monetary', 'display_currency': contract.currency_id}"
                                        />
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
