<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <record id="action_report_supplier_contract" model="ir.actions.report">
    <field name="name">Supplier Contract</field>
    <field name="model">contract.contract</field>
    <field name="report_type">qweb-pdf</field>
    <field
            name="report_name"
        >project_supplier_contract_report.report_supplier_contract</field>
    <field
            name="print_report_name"
        >'Supplier Contract - %s' % (object.name or 'No Reference')</field>
    <field name="binding_model_id" ref="contract.model_contract_contract" />
    <field name="binding_type">report</field>
  </record>
</odoo>
