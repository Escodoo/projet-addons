<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <!-- Contas para testes de folha -->
    <record id="account_salary_payable" model="account.account">
        <field name="name">Folha a Pagar (Demo)</field>
        <field name="code">999900</field>
        <field name="account_type">liability_payable</field>
        <field name="reconcile">True</field>
        <field name="company_id" ref="base.main_company" />
    </record>

    <record id="account_salary_expense" model="account.account">
        <field name="name">Despesa de Salários (Demo)</field>
        <field name="code">999901</field>
        <field name="account_type">expense</field>
        <field name="reconcile">False</field>
        <field name="company_id" ref="base.main_company" />
    </record>

    <record id="account_social_contrib_payable" model="account.account">
        <field name="name">Encargos Sociais a Pagar (Demo)</field>
        <field name="code">999902</field>
        <field name="account_type">liability_payable</field>
        <field name="reconcile">True</field>
        <field name="company_id" ref="base.main_company" />
    </record>

    <record id="account_irrf_payable" model="account.account">
        <field name="name">IRRF a Recolher (Demo)</field>
        <field name="code">999903</field>
        <field name="account_type">liability_payable</field>
        <field name="reconcile">True</field>
        <field name="company_id" ref="base.main_company" />
    </record>

    <!-- Lote de holerites de exemplo configurado para usar as contas demo.
         Os holerites reais e os lançamentos contábeis continuarão sendo
         gerados pelo módulo de folha da sua base, mas este lote já vem
         pré-configurado para testar o botão de Ordem de Pagamento. -->
    <record id="payslip_run_demo_payroll_order" model="hr.payslip.run">
        <field name="name">Lote Folha Demo - Pagamento via Ordem</field>
        <field name="date_start">2026-01-01</field>
        <field name="date_end">2026-01-31</field>
        <field name="company_id" ref="base.main_company" />
        <field name="payment_account_id" ref="account_salary_payable" />
    </record>
</odoo>
